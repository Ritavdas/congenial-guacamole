# Copy to .env.test and fill in. .env.test is gitignored.
# This file is only for Playwright test credentials.
# The app itself still reads its normal local env when `bun run dev` starts.

E2E_CLERK_USER_USERNAME=you@example.com
E2E_CLERK_USER_PASSWORD=your-test-password

# Optional overrides
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1   # set if you start `bun run dev` yourself
