{
  "manifest_version": 3,
  "name": "Pockaa — Save to Read Later",
  "version": "1.0.0",
  "description": "Save any webpage to your Pockaa reading list with one click.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
